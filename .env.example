# DeepSeek API — single source of truth for model id
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional: separate model for synthesis (not enabled in MVP)
# DEEPSEEK_MODEL_SYNTH=deepseek-v4-pro

# DeepSeek retry / timeout tuning
DEEPSEEK_MAX_RETRIES=3    # attempts before giving up (covers 429/5xx)
DEEPSEEK_TIMEOUT=60       # seconds per curl call

# OS tuning
OS_MAX_WORKERS=3          # bounded fan-out parallelism
OS_AGENT_TIMEOUT=90       # seconds per sub-intent (ask.sh) call
OS_HISTORY_WINDOW=6       # turns to include in context (sliding window)
OS_DECOMPOSE_TEMP=0       # temperature for decompose LLM call
OS_SYNTHESIZE_TEMP=0.3    # temperature for synthesize LLM call

# Paths — override if inner-all lives elsewhere
INNER_ALL_DIR=../med-agent-inner-all

# Cache
OS_CACHE_ENABLED=true
OS_KNOWLEDGE_VERSION=1    # bump to invalidate response cache

# Event stream — note: underscore prefix; also enabled per-call via --json flag
_OS_JSON_EVENTS=false
